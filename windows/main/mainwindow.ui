  <property name="styleSheet">
   <string notr="true">/* --- GAMING TITLE (SMOOTH MODERN FONT) --- */
QLabel {
    color: #ffffff;
    font-size: 50px;
    font-weight: 800; /* Bold, but smoother than 900 */
    font-family: &quot;Segoe UI&quot;, &quot;Roboto&quot;, &quot;Montserrat&quot;, &quot;Helvetica Neue&quot;, sans-serif;
    text-transform: uppercase;
    letter-spacing: 12px; /* Spaced out for a cinematic look */
}

/* --- BASE GAMING BUTTON (SMOOTH FONT) --- */
QPushButton {
    background-color: #121212; 
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    font-family: &quot;Segoe UI&quot;, &quot;Roboto&quot;, &quot;Montserrat&quot;, sans-serif;
    text-transform: uppercase;
    letter-spacing: 2px; /* Slight spacing makes text look cleaner */
    border: 2px solid #2a2a2a;
    border-radius: 6px; /* Slightly softer corners */
    padding: 16px;
}

/* --- PLAY VS HUMAN (CYAN NEON) --- */
QPushButton#HumanBtn {
    border-bottom: 4px solid #00f3ff;
}
QPushButton#HumanBtn:hover {
    background-color: #00f3ff;
    color: #000000; 
    border: 2px solid #00f3ff;
    border-bottom: 4px solid #00f3ff;
}
QPushButton#HumanBtn:pressed {
    background-color: #00a4ac;
}

/* --- PLAY VS AI (CRIMSON NEON) --- */
QPushButton#AIBtn {
    border-bottom: 4px solid #ff003c;
}
QPushButton#AIBtn:hover {
    background-color: #ff003c;
    color: #000000;
    border: 2px solid #ff003c;
    border-bottom: 4px solid #ff003c;
}
QPushButton#AIBtn:pressed {
    background-color: #a80026;
}

/* --- RULES (MAGENTA NEON) --- */
QPushButton#rulesBtn {
    border-bottom: 4px solid #d500f9;
}
QPushButton#rulesBtn:hover {
    background-color: #d500f9;
    color: #000000;
    border: 2px solid #d500f9;
    border-bottom: 4px solid #d500f9;
}
QPushButton#rulesBtn:pressed {
    background-color: #9200ab;
}

/* --- QUIT (WARNING ORANGE NEON) --- */
QPushButton#quitBtn {
    border-bottom: 4px solid #ffaa00;
}
QPushButton#quitBtn:hover {
    background-color: #ffaa00;
    color: #000000;
    border: 2px solid #ffaa00;
    border-bottom: 4px solid #ffaa00;
}
QPushButton#quitBtn:pressed {
    background-color: #b37700;
}</string>
